# Mouse Cursor AI - Configuration
# Copy to .env and set your API key

# Simple config - works with Anthropic or any OpenAI-compatible API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-20250514

# ─────────────────────────────────────────────
# Examples for different providers:
# ─────────────────────────────────────────────

# Anthropic (Claude)
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-20250514

# OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Groq (fast + free tier)
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.2-90b-vision-preview

# OpenRouter (many models)
# LLM_API_KEY=sk-or-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-3.5-sonnet

# Together AI
# LLM_API_KEY=...
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3.2-90B-Vision-Instruct-Turbo

# Local (Ollama)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llava
